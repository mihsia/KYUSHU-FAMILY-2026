rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fixed family trip. All writes have strict schemas and verified allow-list access.
    function isAllowed() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'mihsia@gmail.com',
          'pandora0119@gmail.com'
        ];
    }

    function isAdmin() {
      return isAllowed() && request.auth.token.email == 'mihsia@gmail.com';
    }

    function isValidTrip(data) {
      return data.keys().hasOnly([
          'rate', 'rateSource', 'rateUpdatedAt', 'rateUpdatedBy',
          'initialized', 'initializedBy', 'initializedAt', 'updatedAt'
        ])
        && data.rate is number && data.rate > 0 && data.rate <= 100
        && data.rateSource == 'BOT cash sell'
        && data.rateUpdatedAt is timestamp
        && data.rateUpdatedBy is string && data.rateUpdatedBy.size() > 0 && data.rateUpdatedBy.size() <= 128
        && data.initialized is bool
        && data.initializedBy is string && data.initializedBy.size() <= 128
        && data.initializedAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validAudit(data) {
      return data.createdBy is string && data.createdBy.size() <= 128
        && data.createdAt is timestamp
        && data.updatedBy is string && data.updatedBy.size() <= 128
        && data.updatedAt is timestamp;
    }

    function isValidListItem(data) {
      return data.keys().hasOnly([
          'text', 'checked', 'createdBy', 'createdAt', 'updatedBy', 'updatedAt'
        ])
        && data.text is string && data.text.size() > 0 && data.text.size() <= 300
        && data.checked is bool && validAudit(data);
    }

    function isValidPacking(data) {
      return data.keys().hasOnly(['checked', 'updatedBy', 'updatedAt'])
        && data.checked is bool
        && data.updatedBy is string && data.updatedBy.size() <= 128
        && data.updatedAt is timestamp;
    }

    function hasNoReceipt(data) {
      return !data.keys().hasAny(['receiptPath', 'receiptName', 'receiptType', 'receiptSize']);
    }

    function hasValidReceipt(data, expenseId) {
      return data.keys().hasAll(['receiptPath', 'receiptName', 'receiptType', 'receiptSize'])
        && data.receiptPath is string
        && data.receiptPath.matches('^trips/kyushu-2026/receipts/' + expenseId + '/[A-Za-z0-9._-]+$')
        && data.receiptName is string && data.receiptName.size() > 0 && data.receiptName.size() <= 240
        && data.receiptType is string && data.receiptType.matches('^image/(jpeg|png|webp)$')
        && data.receiptSize is int && data.receiptSize > 0 && data.receiptSize <= 10 * 1024 * 1024;
    }

    function hasNoImport(data) {
      return !data.keys().hasAny([
        'originalAmount', 'originalCurrency', 'importSource', 'merchant',
        'items', 'confidence', 'importNotes', 'importDate'
      ]);
    }

    function isValidImportItem(item) {
      return item is map
        && item.keys().hasAll(['name', 'quantity', 'amount'])
        && item.keys().hasOnly(['name', 'quantity', 'amount'])
        && item.name is string && item.name.size() > 0 && item.name.size() <= 100
        && item.quantity is number && item.quantity > 0 && item.quantity <= 10000000
        && item.amount is number && item.amount > 0 && item.amount <= 10000000;
    }

    function isValidImportItems(items) {
      return items is list && items.size() <= 10
        && (items.size() < 1 || isValidImportItem(items[0]))
        && (items.size() < 2 || isValidImportItem(items[1]))
        && (items.size() < 3 || isValidImportItem(items[2]))
        && (items.size() < 4 || isValidImportItem(items[3]))
        && (items.size() < 5 || isValidImportItem(items[4]))
        && (items.size() < 6 || isValidImportItem(items[5]))
        && (items.size() < 7 || isValidImportItem(items[6]))
        && (items.size() < 8 || isValidImportItem(items[7]))
        && (items.size() < 9 || isValidImportItem(items[8]))
        && (items.size() < 10 || isValidImportItem(items[9]));
    }

    function hasValidImport(data) {
      return data.keys().hasAll([
          'originalAmount', 'originalCurrency', 'importSource', 'merchant',
          'items', 'confidence', 'importNotes', 'importDate'
        ])
        && data.originalAmount is number && data.originalAmount > 0 && data.originalAmount <= 10000000
        && data.originalCurrency in ['JPY', 'TWD']
        && data.importSource == 'chatgpt-json-v1'
        && data.merchant is string && data.merchant.size() > 0 && data.merchant.size() <= 100
        && data.items is list && data.items.size() <= 10 && isValidImportItems(data.items)
        && data.confidence is number && data.confidence >= 0 && data.confidence <= 1
        && data.importNotes is string && data.importNotes.size() <= 300
        && data.importDate in [
          '2026-07-13', '2026-07-14', '2026-07-15', '2026-07-16', '2026-07-17'
        ];
    }

    function isValidExpense(data, expenseId) {
      return expenseId.matches('^[A-Za-z0-9_-]+$')
        && data.keys().hasOnly([
          'day', 'category', 'note', 'jpy', 'createdBy', 'createdAt', 'updatedBy', 'updatedAt',
          'receiptPath', 'receiptName', 'receiptType', 'receiptSize',
          'originalAmount', 'originalCurrency', 'importSource', 'merchant',
          'items', 'confidence', 'importNotes', 'importDate'
        ])
        && data.day is int && data.day >= 0 && data.day <= 4
        && data.category in ['餐飲', '交通', '住宿', '購物', '門票', '其他']
        && data.note is string && data.note.size() > 0 && data.note.size() <= 300
        && data.jpy is number && data.jpy > 0 && data.jpy <= 10000000
        && validAudit(data)
        && (hasNoReceipt(data) || hasValidReceipt(data, expenseId))
        && (hasNoImport(data) || hasValidImport(data));
    }

    function isValidDocument(data) {
      return data.keys().hasOnly([
          'category', 'name', 'storagePath', 'contentType', 'size',
          'createdBy', 'createdAt', 'updatedBy', 'updatedAt'
        ])
        && data.category in ['機票', '住宿', 'VJW', '保險', '其他']
        && data.name is string && data.name.size() > 0 && data.name.size() <= 240
        && data.storagePath is string
        && data.storagePath.matches('^trips/kyushu-2026/documents/[^/]+/[^/]+$')
        && (data.contentType == 'application/pdf' || data.contentType.matches('^image/(jpeg|png|webp)$'))
        && data.size is int && data.size > 0 && data.size <= 10 * 1024 * 1024
        && validAudit(data);
    }

    function isValidMember(data, uid) {
      return data.keys().hasOnly(['email', 'displayName', 'photoURL', 'role', 'lastLoginAt'])
        && data.email == request.auth.token.email
        && data.displayName is string && data.displayName.size() <= 100
        && data.photoURL is string && data.photoURL.size() <= 2048
        && data.role == (isAdmin() ? 'admin' : 'member')
        && data.lastLoginAt is timestamp
        && request.auth.uid == uid;
    }

    match /trips/kyushu-2026 {
      allow read: if isAllowed();
      allow create: if isAdmin() && isValidTrip(request.resource.data);
      allow update: if isAllowed() && isValidTrip(request.resource.data)
        && request.resource.data.initialized == resource.data.initialized
        && request.resource.data.initializedBy == resource.data.initializedBy
        && request.resource.data.initializedAt == resource.data.initializedAt;
      allow delete: if false;

      match /wishlist/{itemId} {
        allow read: if isAllowed();
        allow create, update: if isAllowed() && isValidListItem(request.resource.data);
        allow delete: if isAllowed();
      }
      match /mustbuy/{itemId} {
        allow read: if isAllowed();
        allow create, update: if isAllowed() && isValidListItem(request.resource.data);
        allow delete: if isAllowed();
      }
      match /packing/{itemId} {
        allow read: if isAllowed();
        allow create, update: if isAllowed() && isValidPacking(request.resource.data);
        allow delete: if isAllowed();
      }
      match /expenses/{expenseId} {
        allow read: if isAllowed();
        allow create, update: if isAllowed() && isValidExpense(request.resource.data, expenseId);
        allow delete: if isAllowed();
      }
      match /documents/{documentId} {
        allow read: if isAllowed();
        allow create, update: if isAllowed() && isValidDocument(request.resource.data);
        allow delete: if isAllowed();
      }
    }

    match /members/{uid} {
      allow read: if isAllowed() && request.auth.uid == uid;
      allow create, update: if isAllowed() && isValidMember(request.resource.data, uid);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
